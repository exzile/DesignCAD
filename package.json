{
  "name": "dzign3d",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:fresh": "rimraf node_modules/.vite && vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "npx rimraf dist",
    "check:wasm-budget": "node scripts/check-wasm-budget.mjs",
    "verify:wasm-build": "node scripts/verify-wasm-build.mjs",
    "typecheck": "tsc -b",
    "verify": "tsc -b && vitest run",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "graph:analyze": "corepack pnpm dlx --allow-build=@ladybugdb/core --allow-build=tree-sitter --allow-build=tree-sitter-typescript --allow-build=tree-sitter-javascript --allow-build=tree-sitter-cpp --allow-build=tree-sitter-c --allow-build=tree-sitter-cli gitnexus@latest analyze",
    "graph:list": "corepack pnpm dlx --allow-build=@ladybugdb/core --allow-build=tree-sitter --allow-build=tree-sitter-typescript --allow-build=tree-sitter-javascript --allow-build=tree-sitter-cpp --allow-build=tree-sitter-c --allow-build=tree-sitter-cli gitnexus@latest list",
    "graph:mcp": "corepack pnpm dlx --allow-build=@ladybugdb/core --allow-build=tree-sitter --allow-build=tree-sitter-typescript --allow-build=tree-sitter-javascript --allow-build=tree-sitter-cpp --allow-build=tree-sitter-c --allow-build=tree-sitter-cli gitnexus@latest mcp",
    "graph:serve": "corepack pnpm dlx --allow-build=@ladybugdb/core --allow-build=tree-sitter --allow-build=tree-sitter-typescript --allow-build=tree-sitter-javascript --allow-build=tree-sitter-cpp --allow-build=tree-sitter-c --allow-build=tree-sitter-cli gitnexus@latest serve"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "fflate": "^0.8.2",
    "lucide-react": "^1.8.0",
    "mathjs": "^15.2.0",
    "opentype.js": "^1.3.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.183.2",
    "three-bvh-csg": "0.0.17",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "polygon-clipping": "^0.15.7",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4"
  }
}
